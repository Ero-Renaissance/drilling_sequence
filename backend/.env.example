# Copy to .env and fill in your values

# Deployment environment: "development" (default) or "production".
# When set to production, the app refuses to start if DEV_MODE=true or if the
# Azure AD credentials below are missing — auth can never be silently bypassed.
ENVIRONMENT=development

# Database
# Local dev (no Docker needed):
DATABASE_URL=sqlite+aiosqlite:///./drilling_sequence.db
# Production (PostgreSQL via Docker Compose or managed service):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/drilling_sequence
# Production (Microsoft SQL Server via the ODBC Driver 18 — see docs/mssql-migration.md).
# Encrypt=yes is the ODBC 18 default; use a trusted server cert in prod rather than
# TrustServerCertificate=yes. For Azure AD / integrated auth, adjust per IT (open Q2).
# DATABASE_URL=mssql+aioodbc://USER:PASS@HOST:1433/drilling_sequence?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no

# Azure AD — get these from your app registration in Azure Portal
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here

# Set to true to bypass Azure AD auth during local development.
# A fake "Dev User" will be injected automatically. Ignored/rejected when
# ENVIRONMENT=production (the app will refuse to start).
DEV_MODE=true

# Admin access — who gets global admin (can view and manage every campaign).
# ADMIN_ROLE is the Azure AD app role (the token's "roles" claim) that grants admin
# in production — the source of truth. ADMIN_EMAILS is a bootstrap allowlist
# (comma-separated, no spaces; matched case-insensitively) so the first admins exist
# before the AD role is wired up. Both only GRANT admin — a "revoke" in the admin page
# is re-applied at next login, so remove people here (or from the AD role) to revoke.
# In DEV_MODE the dev user is admin automatically; you can leave these blank locally.
ADMIN_EMAILS=first.admin@renaissanceafrica.com,second.admin@renaissanceafrica.com
ADMIN_ROLE=Admin

# Comma-separated list of allowed CORS origins (no spaces around commas)
ALLOWED_ORIGINS=http://localhost:5173

# Single-origin deploy without a reverse proxy: point this at the frontend's built
# `dist/` and uvicorn serves the SPA itself. Leave blank in dev (Vite serves it).
# See docs/deployment-guide.md Appendix C.
# STATIC_DIR=C:\apps\drilling\web

# Email notifications (approvers are emailed when a revision needs their signature).
# Leave SMTP_HOST blank to disable email entirely — the app runs fine without it.
# Point SMTP_HOST at your company's internal SMTP relay once IT provides details.
SMTP_HOST=
SMTP_PORT=25
SMTP_FROM=Renaissance Drilling Sequence <no-reply@renaissanceafrica.com>
# Only needed if the relay requires authentication / TLS:
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
# Public URL of the app, used to build links in notification emails:
APP_BASE_URL=http://localhost:5173
